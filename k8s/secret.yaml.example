# Create the real secret with:
#   kubectl create secret generic dns-deception \
#     --from-literal=DECEPTION_SECRET_KEY=$(openssl rand -hex 32)
#
# Or copy this file to secret.yaml and fill in the base64 value:
#   echo -n $(openssl rand -hex 32) | base64
#
apiVersion: v1
kind: Secret
metadata:
  name: dns-deception
  labels:
    app: dns-deception
type: Opaque
data:
  DECEPTION_SECRET_KEY: ""
